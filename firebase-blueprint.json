{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile photo URL." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Timestamp of the last login." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Character": {
      "title": "Anime Character",
      "description": "A generated anime character with story and stats.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique character ID." },
        "userId": { "type": "string", "description": "The UID of the creator." },
        "name": { "type": "string", "description": "Character name." },
        "story": { "type": "string", "description": "Generated backstory." },
        "japaneseSummary": { "type": "string", "description": "Short Japanese summary." },
        "imageUrl": { "type": "string", "description": "URL to the generated image." },
        "stats": {
          "type": "object",
          "properties": {
            "strength": { "type": "number" },
            "agility": { "type": "number" },
            "intelligence": { "type": "number" },
            "spirit": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the character was created." },
        "isPublic": { "type": "boolean", "description": "Whether the character is visible to others." },
        "likesCount": { "type": "number", "description": "Number of likes received." }
      },
      "required": ["userId", "name", "story", "imageUrl", "stats", "createdAt"]
    },
    "MangaStory": {
      "title": "Manga Story",
      "description": "A generated story involving multiple characters.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique story ID." },
        "userId": { "type": "string", "description": "The UID of the creator." },
        "title": { "type": "string", "description": "Generated title of the story." },
        "content": { "type": "string", "description": "The full story text." },
        "characterIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of the characters involved." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the story was created." }
      },
      "required": ["userId", "title", "content", "characterIds", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles stored by UID."
    },
    "/characters/{characterId}": {
      "schema": "Character",
      "description": "Generated characters collection."
    },
    "/mangaStories/{storyId}": {
      "schema": "MangaStory",
      "description": "Generated manga stories involving multiple characters."
    }
  }
}
